{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "home",
			"postTypes": [
				"page"
			],
			"title": "Home"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"gradients": [
    {
        "gradient": "linear-gradient(135deg, #3858E9 0%, #213FD4 100%)",
        "name": "Degradado azul principal",
        "slug": "primary-gradient"
    },
    {
        "gradient": "linear-gradient(135deg, #3858E9 0%, #F97316 100%)",
        "name": "Degradado comunidad",
        "slug": "community-gradient"
    }
],

			"palette": [
    {
        "color": "#3858E9",
        "name": "Azul WordPress Granada",
        "slug": "primary"
    },
    {
        "color": "#213FD4",
        "name": "Azul oscuro",
        "slug": "primary-dark"
    },
    {
        "color": "#EFF2FF",
        "name": "Azul muy claro",
        "slug": "primary-light"
    },
    {
        "color": "#C7D1FF",
        "name": "Azul suave",
        "slug": "primary-muted"
    },
    {
        "color": "#F97316",
        "name": "Naranja Granada",
        "slug": "accent"
    },
    {
        "color": "#FFF7ED",
        "name": "Naranja claro",
        "slug": "accent-light"
    },
    {
        "color": "#FFFFFF",
        "name": "Blanco",
        "slug": "base"
    },
    {
        "color": "#F5F7FA",
        "name": "Fondo claro",
        "slug": "background-light"
    },
    {
        "color": "#101828",
        "name": "Texto principal",
        "slug": "contrast"
    },
    {
        "color": "#344054",
        "name": "Texto secundario",
        "slug": "secondary"
    },
    {
        "color": "#667085",
        "name": "Texto suave",
        "slug": "muted"
    }
]
		},
		"custom": {
			"borderRadius": {
				"large": "12px",
				"medium": "8px",
				"pill": "100px",
				"small": "4px"
			},
			"spacing": {
				"section": "5rem"
			}
		},
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1440px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "1",
					"size": "0.25rem",
					"slug": "10"
				},
				{
					"name": "2",
					"size": "0.5rem",
					"slug": "20"
				},
				{
					"name": "3",
					"size": "0.75rem",
					"slug": "30"
				},
				{
					"name": "4",
					"size": "1rem",
					"slug": "40"
				},
				{
					"name": "5",
					"size": "1.5rem",
					"slug": "50"
				},
				{
					"name": "6",
					"size": "2rem",
					"slug": "60"
				},
				{
					"name": "7",
					"size": "2.5rem",
					"slug": "70"
				},
				{
					"name": "8",
					"size": "3rem",
					"slug": "80"
				},
				{
					"name": "9",
					"size": "3.5rem",
					"slug": "90"
				},
				{
					"name": "10",
					"size": "5rem",
					"slug": "100"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontStyle": "normal",
							"fontWeight": "700 800",
							"src": [
								"file:./assets/fonts/plus-jakarta-sans-latin.woff2"
							],
							"unicodeRange": "U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD"
						},
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontStyle": "normal",
							"fontWeight": "700 800",
							"src": [
								"file:./assets/fonts/plus-jakarta-sans-latin-ext.woff2"
							],
							"unicodeRange": "U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF"
						}
					],
					"fontFamily": "'Plus Jakarta Sans', sans-serif",
					"name": "Plus Jakarta Sans",
					"slug": "heading"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"src": [
								"file:./assets/fonts/inter-latin.woff2"
							],
							"unicodeRange": "U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD"
						},
						{
							"fontFamily": "Inter",
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"src": [
								"file:./assets/fonts/inter-latin-ext.woff2"
							],
							"unicodeRange": "U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF"
						}
					],
					"fontFamily": "'Inter', sans-serif",
					"name": "Inter",
					"slug": "body"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Extra Small",
					"size": "0.8125rem",
					"slug": "x-small"
				},
				{
					"fluid": {
						"max": "0.9375rem",
						"min": "0.875rem"
					},
					"name": "Small",
					"size": "0.9375rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.0625rem",
						"min": "0.9375rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.25rem",
						"min": "1.0625rem"
					},
					"name": "Large",
					"size": "1.25rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "1.5rem",
						"min": "1.25rem"
					},
					"name": "Extra Large",
					"size": "1.5rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "2.25rem",
						"min": "1.5rem"
					},
					"name": "2X Large",
					"size": "2.25rem",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "1.875rem"
					},
					"name": "Huge",
					"size": "3rem",
					"slug": "huge"
				},
				{
					"fluid": {
						"max": "3.75rem",
						"min": "1.75rem"
					},
					"name": "Gigantic",
					"size": "3.75rem",
					"slug": "gigantic"
				},
				{
					"fluid": {
						"max": "4.5rem",
						"min": "2.25rem"
					},
					"name": "Colossal",
					"size": "4.5rem",
					"slug": "colossal"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"button": {
    ":hover": {
        "color": {
            "background": "var(--wp--preset--color--primary-dark)",
            "text": "var(--wp--preset--color--base)"
        }
    },
    "border": {
        "radius": "100px"
    },
    "color": {
        "background": "var(--wp--preset--color--primary)",
        "text": "var(--wp--preset--color--base)"
    },
    "spacing": {
        "padding": {
            "top": "0.85rem",
            "right": "1.4rem",
            "bottom": "0.85rem",
            "left": "1.4rem"
        }
    },
    "typography": {
        "fontFamily": "var(--wp--preset--font-family--body)",
        "fontSize": "var(--wp--preset--font-size--medium)",
        "fontWeight": "700",
        "lineHeight": "1.2"
    }
}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--gigantic)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--huge)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "800",
					"lineHeight": "1.2"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-dark)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			}
		},
		"spacing": {
			"blockGap": "0 0 25px 0",
			"padding": {
				"left": "0",
				"right": "0"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}